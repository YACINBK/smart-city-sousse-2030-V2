# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://neo_user:neo_password@localhost:5432/neo_sousse

# LLM
OPENAI_API_KEY=sk-...
USE_MOCK_LLM=false
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# FSM
HORS_SERVICE_ALERT_DELAY_SECONDS=86400

# Features
TIMESCALE_ENABLED=true
FSM_HISTORY_ENABLED=true
